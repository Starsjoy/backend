    "fragment:verify": "python3 modules/usdtStars/fragment_cli.py --verify-cookies"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "mkdirp": "^1.0.4",
    "node-fetch": "^3.3.2",
    "pg": "^8.11.5",
    "readline-sync": "^1.4.10",
    "socks-proxy-agent": "^8.0.5",
    "telegraf": "^4.16.3",
    "telegram": "^2.26.22"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
