{
  "name": "telegram-save-server",
  "version": "1.0.0",
  "type": "module",
  "main": "main.js",
  "scripts": {
    "start": "node main.js",
    "start:server": "node server.js",
    "start:sms": "node balanceChecker.js",
    "start:bot": "node token.js",
    "dev": "nodemon main.js",
    "fragment:install": "npm install socks-proxy-agent && pip3 install -r requirements.txt",
